<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Relatório Financeiro — IPnovaEusébio{% endblock %}</title>
    <style>
        @page {
            size: A4 landscape;
            margin: 0;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: Arial, Helvetica, sans-serif;
            color: #2d3436;
            background-color: #ffffff;
            -webkit-print-color-adjust: exact;
        }

        .slide {
            width: 297mm;
            height: 210mm;
            position: relative;
            overflow: hidden;
            display: -webkit-box;
            display: -webkit-flex;
            display: flex;
            -webkit-box-orient: vertical;
            -webkit-flex-direction: column;
            flex-direction: column;
            box-sizing: border-box;
        }

        .accent-bar {
            position: absolute;
            top: 0;
            left: 0;
            width: 8px;
            height: 100%;
            background-color: #0984e3;
        }

        header {
            padding: 28px 50px 14px 70px;
            display: -webkit-box;
            display: -webkit-flex;
            display: flex;
            -webkit-box-pack: justify;
            -webkit-justify-content: space-between;
            justify-content: space-between;
            -webkit-box-align: center;
            -webkit-align-items: center;
            align-items: center;
        }

        header h1 {
            margin: 0;
            font-size: 22pt;
            font-weight: 700;
            color: #2d3436;
            border-bottom: 4px solid #0984e3;
            padding-bottom: 6px;
        }

        main {
            -webkit-box-flex: 1;
            -webkit-flex: 1;
            flex: 1;
            padding: 10px 50px 10px 70px;
            font-size: 13pt;
            line-height: 1.5;
            display: -webkit-box;
            display: -webkit-flex;
            display: flex;
            -webkit-box-orient: vertical;
            -webkit-flex-direction: column;
            flex-direction: column;
            -webkit-box-pack: center;
            -webkit-justify-content: center;
            justify-content: center;
        }

        footer {
            height: 38px;
            background-color: #f5f6fa;
            padding: 0 50px 0 70px;
            display: -webkit-box;
            display: -webkit-flex;
            display: flex;
            -webkit-box-pack: justify;
            -webkit-justify-content: space-between;
            justify-content: space-between;
            -webkit-box-align: center;
            -webkit-align-items: center;
            align-items: center;
            font-size: 9pt;
            color: #636e72;
        }

        /* Classes Utilitárias */
        .grid-2 {
            display: grid;
        }

        .grid-2 {
            display: -webkit-box;
            display: -webkit-flex;
            display: flex;
            gap: 25px;
        }

        .grid-2 > * {
            -webkit-box-flex: 1;
            -webkit-flex: 1;
            flex: 1;
        }

        .metric-card {
            background: #f5f6fa;
            border-radius: 8px;
            padding: 18px 22px;
            border-left: 4px solid #0984e3;
            margin-bottom: 14px;
        }

        .metric-label {
            font-size: 10pt;
            color: #636e72;
            margin-bottom: 6px;
        }

        .metric-value {
            font-size: 20pt;
            font-weight: 700;
            color: #2d3436;
        }

        .metric-value.positive { color: #00857a; }
        .metric-value.negative { color: #c0392b; }

        .chart-container {
            text-align: center;
        }

        .chart-container img {
            max-width: 100%;
            max-height: 240px;
        }

        /* Capa */
        .slide.cover {
            -webkit-box-pack: center;
            -webkit-justify-content: center;
            justify-content: center;
            -webkit-box-align: center;
            -webkit-align-items: center;
            align-items: center;
            text-align: center;
            background: linear-gradient(135deg, #ffffff 0%, #877cb0 100%);
        }

        .slide.cover .logo-container img {
            max-height: 110px;
            margin-bottom: 25px;
        }

        .slide.cover h1 {
            font-size: 40pt;
            margin: 0 0 10px 0;
            color: #2d3436;
            border: none;
        }

        .slide.cover h2 {
            font-size: 20pt;
            font-weight: 300;
            color: #636e72;
            margin: 0;
        }

        ul { padding-left: 22px; }
        li { margin-bottom: 10px; }
    </style>
</head>
<body>
    <div class="slide {% block slide_class %}{% endblock %}">
        {% block content %}{% endblock %}
        {% block footer %}
        <footer>
            <span>IPNova Eusébio — Relatório Financeiro</span>
            <span>Gerado em {{ data_geracao }}</span>
        </footer>
        {% endblock %}
    </div>
</body>
</html>